# Threat Detection System Configuration
# Copy this file to .env and uncomment/modify the settings you want to use

# Global threat detection settings
THREAT_DETECTION_ENABLED=true
THREAT_DETECTION_MODE=monitor
THREAT_DETECTION_PARALLEL=true
THREAT_DETECTION_TIMEOUT=5
THREAT_DETECTION_AGGREGATION_RULE=any_block
THREAT_DETECTION_CONFIDENCE_THRESHOLD=0.7

# Google Model Armor Configuration (using Google Cloud client library)
# GOOGLE_MODEL_ARMOR_ENABLED=true
# GOOGLE_MODEL_ARMOR_PROJECT_ID=your-gcp-project-id
# GOOGLE_MODEL_ARMOR_LOCATION=us-central1
# GOOGLE_MODEL_ARMOR_TEMPLATE_ID=default
# GOOGLE_MODEL_ARMOR_SERVICE_ACCOUNT_PATH=/path/to/service-account-key.json
# GOOGLE_MODEL_ARMOR_MODE=monitor

# Azure Content Safety Configuration
# AZURE_CONTENT_SAFETY_ENABLED=true
# AZURE_CONTENT_SAFETY_KEY=your_azure_content_safety_key
# AZURE_CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com/contentsafety/text:analyze
# AZURE_CONTENT_SAFETY_MODE=monitor

# OpenAI Moderation Configuration
# OPENAI_MODERATION_ENABLED=true
# OPENAI_MODERATION_KEY=your_openai_api_key
# OPENAI_MODERATION_ENDPOINT=https://api.openai.com/v1/moderations
# OPENAI_MODERATION_MODE=monitor

# Custom Rule-Based Detection Configuration
# CUSTOM_RULES_ENABLED=true
# CUSTOM_RULES_MODE=monitor
# CUSTOM_THREAT_KEYWORDS=ignore previous instructions,system prompt,jailbreak,bypass

# Configuration Options Explained:
#
# THREAT_DETECTION_ENABLED: Enable/disable the entire threat detection system
# THREAT_DETECTION_MODE: Global default mode (monitor/block/disabled)
# THREAT_DETECTION_PARALLEL: Run providers in parallel (true) or sequentially (false)
# THREAT_DETECTION_TIMEOUT: Timeout in seconds for threat detection analysis
# THREAT_DETECTION_AGGREGATION_RULE: How to combine results from multiple providers
#   - any_block: Block if ANY provider detects a threat
#   - majority_block: Block if MAJORITY of providers detect a threat
#   - consensus_block: Block only if ALL providers detect a threat
#   - threshold_block: Block if confidence score exceeds threshold
# THREAT_DETECTION_CONFIDENCE_THRESHOLD: Confidence threshold for threshold_block rule (0.0-1.0)
#
# Provider-specific modes:
# - monitor: Log threats but don't block execution
# - block: Block execution if threats are detected
# - disabled: Skip this provider entirely
